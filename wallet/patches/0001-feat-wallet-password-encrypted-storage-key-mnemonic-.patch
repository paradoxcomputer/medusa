diff --git a/wallet/src/crypto.rs b/wallet/src/crypto.rs
new file mode 100644
index 0000000..5d2e31c
--- /dev/null
+++ b/wallet/src/crypto.rs
@@ -0,0 +1,123 @@
+//! Password-based encryption of the wallet's persistent storage.
+//!
+//! The wallet's secrets (per-account signing keys, the recovery mnemonic) live in
+//! the persistent storage file. To keep them at rest behind the user's password we
+//! derive a 256-bit key from the password with Argon2id (memory-hard, salted) and
+//! seal the serialized storage with AES-256-GCM (authenticated, so a wrong password
+//! fails cleanly rather than yielding garbage). The on-disk form is a small,
+//! self-describing JSON envelope.
+
+use aes_gcm::{
+    Aes256Gcm, Key, Nonce,
+    aead::{Aead, KeyInit},
+};
+use anyhow::{Context as _, Result, anyhow, bail};
+use argon2::Argon2;
+use base64::{Engine as _, engine::general_purpose::STANDARD as B64};
+use rand::RngCore as _;
+use serde::{Deserialize, Serialize};
+use zeroize::Zeroize as _;
+
+const ENVELOPE_VERSION: u8 = 1;
+const SALT_LEN: usize = 16;
+const NONCE_LEN: usize = 12;
+const KEY_LEN: usize = 32;
+
+/// Self-describing on-disk envelope around the AES-256-GCM ciphertext.
+#[derive(Serialize, Deserialize)]
+struct Envelope {
+    /// Envelope format version.
+    v: u8,
+    /// Key-derivation function identifier (currently always `argon2id`).
+    kdf: String,
+    /// Argon2 salt, hex-encoded.
+    salt: String,
+    /// AES-GCM nonce, hex-encoded.
+    nonce: String,
+    /// AES-256-GCM ciphertext (incl. tag), base64-encoded.
+    ct: String,
+}
+
+fn derive_key(password: &str, salt: &[u8]) -> Result<[u8; KEY_LEN]> {
+    let mut key = [0_u8; KEY_LEN];
+    Argon2::default()
+        .hash_password_into(password.as_bytes(), salt, &mut key)
+        .map_err(|e| anyhow!("key derivation failed: {e}"))?;
+    Ok(key)
+}
+
+/// Encrypt `plaintext` under `password`, returning the JSON envelope bytes to persist.
+pub fn encrypt(plaintext: &[u8], password: &str) -> Result<Vec<u8>> {
+    let mut salt = [0_u8; SALT_LEN];
+    let mut nonce_bytes = [0_u8; NONCE_LEN];
+    rand::rngs::OsRng.fill_bytes(&mut salt);
+    rand::rngs::OsRng.fill_bytes(&mut nonce_bytes);
+
+    let mut key = derive_key(password, &salt)?;
+    let cipher = Aes256Gcm::new(Key::<Aes256Gcm>::from_slice(&key));
+    let ct = cipher
+        .encrypt(Nonce::from_slice(&nonce_bytes), plaintext)
+        .map_err(|_| anyhow!("encryption failed"))?;
+    key.zeroize();
+
+    let envelope = Envelope {
+        v: ENVELOPE_VERSION,
+        kdf: "argon2id".to_owned(),
+        salt: hex::encode(salt),
+        nonce: hex::encode(nonce_bytes),
+        ct: B64.encode(&ct),
+    };
+    Ok(serde_json::to_vec_pretty(&envelope)?)
+}
+
+/// Decrypt an envelope produced by [`encrypt`]. A wrong password (or tampering)
+/// surfaces as an authentication error, never as corrupted plaintext.
+pub fn decrypt(envelope_bytes: &[u8], password: &str) -> Result<Vec<u8>> {
+    let envelope: Envelope = serde_json::from_slice(envelope_bytes)
+        .context("storage is not a valid encrypted envelope")?;
+    if envelope.v != ENVELOPE_VERSION {
+        bail!("unsupported storage envelope version {}", envelope.v);
+    }
+    let salt = hex::decode(&envelope.salt).context("malformed salt")?;
+    let nonce_bytes = hex::decode(&envelope.nonce).context("malformed nonce")?;
+    let ct = B64
+        .decode(envelope.ct.as_bytes())
+        .context("malformed ciphertext")?;
+
+    let mut key = derive_key(password, &salt)?;
+    let cipher = Aes256Gcm::new(Key::<Aes256Gcm>::from_slice(&key));
+    let plaintext = cipher
+        .decrypt(Nonce::from_slice(&nonce_bytes), ct.as_ref())
+        .map_err(|_| anyhow!("invalid password or corrupt storage"));
+    key.zeroize();
+    plaintext
+}
+
+/// True if `bytes` look like an encrypted envelope (vs. legacy plaintext storage).
+pub fn is_encrypted(bytes: &[u8]) -> bool {
+    serde_json::from_slice::<Envelope>(bytes).is_ok()
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn round_trip() {
+        let pt = b"{\"accounts\":[],\"last_synced_block\":7}";
+        let env = encrypt(pt, "correct horse").unwrap();
+        assert!(is_encrypted(&env));
+        assert_eq!(decrypt(&env, "correct horse").unwrap(), pt);
+    }
+
+    #[test]
+    fn wrong_password_fails() {
+        let env = encrypt(b"secret", "right").unwrap();
+        assert!(decrypt(&env, "wrong").is_err());
+    }
+
+    #[test]
+    fn legacy_plaintext_not_detected_as_encrypted() {
+        assert!(!is_encrypted(b"{\"accounts\":[],\"last_synced_block\":0,\"labels\":{}}"));
+    }
+}
